{
  "expo": {
    "name": "Pem",
    "slug": "pem",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pem-icon-1024-transparent.png",
    "scheme": "pem",
    "platforms": ["ios", "web"],
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Pem uses the microphone to turn what you say into on-device text for your dump.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      },
      "bundleIdentifier": "com.anonymous.pem"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/pem-icon-1024-transparent.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#e8763a"
        }
      ],
      "expo-audio",
      "expo-web-browser",
      "expo-secure-store",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
