## Types

### All shared types in `types/` directory
```
types/
  message.types.ts
  task.types.ts
  calendar.types.ts
  user.types.ts
  sse.types.ts
```

### Use types, not interfaces for data shapes
```typescript
// ✓ type for data
export type Message = {
  id: string
  userId: string
  role: 'user' | 'pem'
  kind: 'text' | 'voice' | 'brief' | 'status'
  content: string | null
  voiceUrl: string | null
  transcript: string | null
  intent: Intent | null
  createdAt: Date
}

// ✓ interface for things that get implemented (services, repositories)
export interface MessageRepository {
  findByUser(userId: string, options: PaginationOptions): Promise<Message[]>
  save(message: CreateMessageDto): Promise<Message>
}
```

### Enums as const objects, not TypeScript enums
```typescript
// ✓ Const object — better tree-shaking, works with Zod
export const Intent = {
  DUMP: 'dump',
  COMMAND: 'command',
  QUESTION: 'question',
} as const
export type Intent = typeof Intent[keyof typeof Intent]

// ✗ TypeScript enum — runtime overhead, worse DX
enum Intent {
  DUMP = 'dump',
  COMMAND = 'command',
  QUESTION = 'question',
}
```

