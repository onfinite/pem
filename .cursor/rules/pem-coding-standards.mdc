## Hooks

### Extract all logic from components into hooks
Components render. Hooks think.

A component that has more than 2-3 useState or useEffect calls needs a hook.

```tsx
// ✗ Logic mixed into component
export function ChatInput() {
  const [text, setText] = useState('')
  const [isRecording, setIsRecording] = useState(false)
  const [recordingDuration, setRecordingDuration] = useState(0)
  const [uploadProgress, setUploadProgress] = useState(0)
  const timerRef = useRef<NodeJS.Timeout>()

  useEffect(() => {
    if (isRecording) {
      timerRef.current = setInterval(() => {
        setRecordingDuration(d => d + 1)
      }, 1000)
    }
    return () => clearInterval(timerRef.current)
  }, [isRecording])

  // ...30 more lines of logic
}

// ✓ Logic in a hook
export function ChatInput() {
  const { text, setText, isTyping } = useChatText()
  const { isRecording, duration, startRecording, stopRecording } = useVoiceRecording()

  return isRecording
    ? <RecordingBar duration={duration} onStop={stopRecording} />
    : <TextBar text={text} onChange={setText} onMicPress={startRecording} isTyping={isTyping} />
}
```

### Hook file structure
```typescript
// useChatMessages.ts
export function useChatMessages(userId: string) {
  // state
  // refs
  // derived values
  // effects
  // handlers

  return {
    messages,
    isLoading,
    hasError,
    sendMessage,
    loadMore,
  }
}
```

Only return what the component needs. Don't return internal state.

