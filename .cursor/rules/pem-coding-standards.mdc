## Utils

### One function per util file (usually)
```
utils/
  formatDuration.ts       ← formats 0:23 from seconds
  formatRelativeDate.ts   ← "Today", "Yesterday", "Apr 6"
  isOverdue.ts            ← checks if a task is overdue
  groupByDate.ts          ← groups messages by date
  truncateText.ts         ← truncates with ellipsis
  parseIntent.ts          ← maps string to Intent enum
```

### Utils are pure functions — no side effects, no imports from app code
```typescript
// ✓ Pure, testable, reusable
export function formatDuration(seconds: number): string {
  const m = Math.floor(seconds / 60)
  const s = seconds % 60
  return `${m}:${s.toString().padStart(2, '0')}`
}

// ✗ Has side effects, hard to test
export function formatAndLogDuration(seconds: number): string {
  const result = `${Math.floor(seconds / 60)}:${seconds % 60}`
  console.log('duration:', result)
  return result
}
```

