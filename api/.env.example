DATABASE_URL=

PORT=8000
ENV=dev

# Comma-separated origins (matches FastAPI `allowed_origins`)
ALLOWED_ORIGINS=https://heypem.com,http://localhost:8081
DEFAULT_RATE_LIMIT="100/minute"
MAX_REQUEST_SIZE=5_000_000  # 5MB for dumps

REDIS_URL=

OPENAI_API_KEY=
SENTRY_SDK_DSN=

CLERK_WEBHOOK_SECRET=
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=

# Models
OPENAI_MODEL=gpt-4o-mini
OPENAI_AGENT_MODEL=gpt-4o

# Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=

# R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=