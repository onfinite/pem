DATABASE_URL=

PORT=8000
ENV=dev

# Comma-separated origins (matches FastAPI `allowed_origins`)
ALLOWED_ORIGINS=https://heypem.com,http://localhost:8081
DEFAULT_RATE_LIMIT="100/minute"
MAX_REQUEST_SIZE=5_000_000  # 5MB for dumps

# BullMQ + chat SSE (TCP). Local: redis://127.0.0.1:6379. Prod: Upstash “Redis” URL, or leave empty and use REST pair below.
REDIS_URL=

# Upstash REST — enables @upstash/redis via UpstashRestRedisService; if REDIS_URL is empty, TCP URL for Bull/ioredis is derived from the same host.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

OPENAI_API_KEY=

CLERK_WEBHOOK_SECRET=
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=

# Models
OPENAI_MODEL=gpt-4o-mini
OPENAI_AGENT_MODEL=gpt-4o

# Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
GOOGLE_OAUTH_STATE_SECRET=

# R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=