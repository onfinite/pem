{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "setupFiles": ["<rootDir>/setup-e2e.ts"],
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": ["/node_modules/(?!jose/).+\\.js$"],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^expo-server-sdk$": "<rootDir>/mocks/expo-server-sdk.ts"
  }
}
