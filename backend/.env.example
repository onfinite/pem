# Sync URL to PostgreSQL (same role as `database_url_sync` in `api/.env`)
DATABASE_URL=postgresql://user:pass@localhost:5432/pem

# Optional: alias supported by ConfigModule (same as FastAPI `database_url_sync`)
# DATABASE_URL_SYNC=

PORT=8000
ENV=dev

# Comma-separated origins (matches FastAPI `allowed_origins`)
ALLOWED_ORIGINS=https://heypem.com,http://localhost:8081

# Clerk — same semantics as `api/app/core/config.py`
CLERK_JWKS_URL=https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWT_ISSUER=https://YOUR_INSTANCE.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_...

# BullMQ + prep workers
REDIS_URL=redis://127.0.0.1:6379

# Agents (Vercel AI SDK + OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
AGENT_MAX_STEPS=8
# Composite multi-section briefs (optional)
# COMPOSITE_AGENT_MAX_STEPS=14
# COMPOSITE_DETECT_TIMEOUT_MS=25000
# Parallel sub-agents per composite prep (default on; set false for one loop)
# COMPOSITE_FANOUT_ENABLED=true
# COMPOSITE_FANOUT_MAX_LANES=4
# COMPOSITE_FANOUT_MAX_STEPS_PER_LANE=8
# COMPOSITE_FANOUT_PLAN_TIMEOUT_MS=20000
# Merge lane transcripts before COMPOSITE_BRIEF JSON (default on)
# COMPOSITE_MERGE_ENABLED=true
# COMPOSITE_MERGE_TIMEOUT_MS=120000

# Web search — Tavily (synthesis) + SerpAPI (Google Shopping / Maps / organic)
TAVILY_API_KEY=tvly-...
SERP_API_KEY=...
